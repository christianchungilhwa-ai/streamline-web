# Dev port for the Express dev proxy. Vite sits at 5002 and forwards /api → :3003.
PORT=3003

# Where /api/* requests get forwarded in dev. Default = local claraity-server.
# Set to https://claraity.app to test against production Claraity routes.
CLARAITY_PROXY_TARGET=http://localhost:3001

# Production-only — base URL the browser uses for /api/* calls in the
# Vite-built SPA. Leave blank in dev (the dev-proxy handles it).
VITE_API_BASE_URL=https://claraity.app
